{
    "bitfile": "bitfiles/iir2nd_direct_gpio.bit",
    "description": "Second-order IIR filter with direct form implementation. Includes upstream integrator that reduces sampling rate by 2^LOG_DIV factor.",
    "build_date": "2025-01-14",
    "modules": {    
        "filt0": {
            "type": "iir2nd_direct",
            "settings": { 
                "LOG_DIV": 10,
                "LOG_A0": 30,
                "LOG_UNITY_GAIN": 9,
                "DATA_WIDTH": 32,
                "COEFF_WIDTH": 32,
                "GAIN_WIDTH": 18,
                "timebase_rp": 8e-9,
                "timebase_module": 8.192e-6
            },
            "registers": {
                "b0":    {"base": "0x41200000", "offset":  0, "msb": 31, "lsb": 0, "signed": true,  "log_scale": 30},
                "b1":    {"base": "0x41200000", "offset":  8, "msb": 31, "lsb": 0, "signed": true,  "log_scale": 30},
                "b2":    {"base": "0x41210000", "offset":  0, "msb": 31, "lsb": 0, "signed": true,  "log_scale": 30},
                "a1":    {"base": "0x41210000", "offset":  8, "msb": 31, "lsb": 0, "signed": true,  "log_scale": 30},
                "a2":    {"base": "0x41220000", "offset":  0, "msb": 31, "lsb": 0, "signed": true,  "log_scale": 30},
                "gain":  {"base": "0x41220000", "offset":  8, "msb": 17, "lsb": 0, "signed": false, "log_scale": 9},
                "reset": {"base": "0x41220000", "offset":  8, "msb": 31,  "lsb": 31, "signed": false,  "log_scale":0}
                }                   
            }
        }
  }

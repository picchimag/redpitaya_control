{
    "bitfile": "bitfiles/stream_cdma_4ch.bit",
    "description": "4-channel streaming module with AXI CDMA for fast data transfer to DDR memory. Each sample = 4ch × 16-bit = 64-bit = 8 bytes. Frame of 1024 samples = 8192 bytes.",
    "build_date": "2025-11-05",

    "modules": {
        "stream4ch": {
            "type": "stream4channel_axi_wrap",
            "settings": {
                "sample_width_bits": 16,
                "num_channels": 4,
                "bram_addr_bits": 11,
                "decimation_bits": 8,
                "timebase_rp_sec": 8e-9,
                "timebase_module_sec": 8e-9,
                
                "comment_data_format": "Each BRAM word packs 4 channels into 64 bits",
                "bram_word_width_bits": 64,
                "bram_word_width_bytes": 8,
                "bram_depth_words": 2048,
                "bram_size_bytes": 16384,
                
                "comment_addresses": "Memory-mapped addresses",
                "bram_base_addr": "0x41000000",
                "cdma_ctrl_addr": "0x7E200000",
                "ddr_target_addr": "0x10000000"
            },
            "registers": {
                "frame_len": {"base": "0x40000000", "offset": 0, "msb": 11, "lsb": 0, "signed": false, "log_scale": 0, "description": "Number of samples to capture (1-2048). Note: samples, not bytes!"},
                "log_div":   {"base": "0x40000000", "offset": 4, "msb": 7, "lsb": 0, "signed": false, "log_scale": 0, "description": "Decimation factor = 2^log_div (0=125MHz, 1=62.5MHz, etc)"},
                "arm":       {"base": "0x40000000", "offset": 8, "msb": 0, "lsb": 0, "signed": false, "log_scale": 0, "description": "Arm capture (write 1 to start)"},
                "ack":       {"base": "0x40000000", "offset": 12, "msb": 0, "lsb": 0, "signed": false, "log_scale": 0, "description": "Acknowledge frame (write 1 then 0)"},
                "status":    {"base": "0x40000000", "offset": 28, "msb": 31, "lsb": 0, "signed": false, "log_scale": 0, "readonly": true, "description": "[31]=sample_tick, [21:11]=wr_idx, [10:3]=seq, [0]=ready"}
            }
       
        }
    }
}

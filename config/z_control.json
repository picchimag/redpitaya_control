{
  "bitfile": "bitfiles/z_control.bit",
  "description": "output0  = pid(input0)+filt(input1), output1  = pid(input2). Connect zQPD to in0, and zRF to ion 1.Then connect out0 to zFB and out1 to Zphase control",


  "build_date": "2025-10-01",

  "modules": {

    


    "filt0": {
      "type": "iir2nd_direct",
      "settings": {   "LOG_DIV": 10,
                      "LOG_A0": 30,
                      "LOG_UNITY_GAIN": 9,
                      "DATA_WIDTH": 32,
                      "COEFF_WIDTH": 32,
                      "GAIN_WIDTH": 18,
                      "timebase_rp": 8e-9,
                      "timebase_module": 8.192e-6
                  },
      "registers": {
                  "b0":    {"base": "0x40003000", "offset":  0, "msb": 31, "lsb": 0, "signed": true,  "log_scale": 30},
                  "b1":    {"base": "0x40003000", "offset":  4, "msb": 31, "lsb": 0, "signed": true,  "log_scale": 30},
                  "b2":    {"base": "0x40003000", "offset":  8, "msb": 31, "lsb": 0, "signed": true,  "log_scale": 30},
                  "a1":    {"base": "0x40003000", "offset": 12, "msb": 31, "lsb": 0, "signed": true,  "log_scale": 30},
                  "a2":    {"base": "0x40003000", "offset": 16, "msb": 31, "lsb": 0, "signed": true,  "log_scale": 30},
                  "gain":  {"base": "0x40003000", "offset": 20, "msb": 17, "lsb": 0, "signed": false, "log_scale": 9},
                  "reset": {"base": "0x40003000", "offset": 24, "msb": 0,  "lsb": 0, "signed": false,  "log_scale":0}
                  }
  },

    "filt1": {
        "type": "iir2nd_coupled",
        "settings": { "LOG_DIV": 10,
                        "LOG_A0": 19,
                        "LOG_UNITY_GAIN": 10,
                        "DATA_WIDTH": 20,
                        "COEFF_WIDTH": 20,
                        "GAIN_WIDTH": 18,
                        "timebase_rp": 8e-9,
                        "timebase_module": 8.192e-6
                    },
        "registers": {
                    "alpha": {"base": "0x40000000", "offset":  0, "msb": 31, "lsb": 0, "signed": true,  "log_scale": 19},
                    "beta" : {"base": "0x40000000", "offset":  4, "msb": 31, "lsb": 0, "signed": true,  "log_scale": 19},
                    "gainI": {"base": "0x40000000", "offset":  8, "msb": 31, "lsb": 0, "signed": false, "log_scale": 10},
                    "gainQ": {"base": "0x40000000", "offset": 12, "msb": 31, "lsb": 0, "signed": false, "log_scale": 10},
                    "reset": {"base": "0x40000000", "offset": 16, "msb": 0,  "lsb": 0, "signed": false, "log_scale": 0}
                    }
    },

    "pid0": {
      "type": "pid_simple",
      "settings": {
        "LOG_DIV": 10,
        "LOG_A0": 16,
        "DATA_WIDTH": 32,
        "COEFF_WIDTH": 32,
        "GAIN_WIDTH": 18,
        "LOG_UNITY_GAIN": 9,
        "timebase_rp": 8e-9,
        "timebase_module": 8.192e-6
        },
      "registers": {
        "setpoint": {"base": "0x40001000", "offset": 0,  "msb": 31, "lsb": 0, "signed": true, "log_scale": 31},
        "Kp":       {"base": "0x40001000", "offset": 4,  "msb": 31, "lsb": 0, "signed": true, "log_scale": 16},
        "Ki":       {"base": "0x40001000", "offset": 8,  "msb": 31, "lsb": 0, "signed": true, "log_scale": 16},
        "Kd":       {"base": "0x40001000", "offset": 12, "msb": 31, "lsb": 0, "signed": true, "log_scale": 16},
        "alpha_d":  {"base": "0x40001000", "offset": 16, "msb": 31, "lsb": 0, "signed": true, "log_scale": 31},
        "gain":     {"base": "0x40001000", "offset": 20, "msb": 17, "lsb": 0, "signed": false, "log_scale": 9},
        "ireset":   {"base": "0x40001000", "offset": 24, "msb": 1,  "lsb": 1, "signed": false, "log_scale": 0},
        "reset":    {"base": "0x40001000", "offset": 24, "msb": 0,  "lsb": 0, "signed": false, "log_scale": 0}
      }
    },



    "pid1": {
      "type": "pid_simple",
      "settings": {
        "LOG_DIV": 10,
        "LOG_A0": 16,
        "DATA_WIDTH": 32,
        "COEFF_WIDTH": 32,
        "GAIN_WIDTH": 18,
        "LOG_UNITY_GAIN": 9,
        "timebase_rp": 8e-9,
        "timebase_module": 8.192e-6
        },
        "registers": {
        "setpoint": {"base": "0x40002000", "offset": 0,  "msb": 31, "lsb": 0, "signed": true, "log_scale": 31},
        "Kp":       {"base": "0x40002000", "offset": 4,  "msb": 31, "lsb": 0, "signed": true, "log_scale": 16},
        "Ki":       {"base": "0x40002000", "offset": 8,  "msb": 31, "lsb": 0, "signed": true, "log_scale": 16},
        "Kd":       {"base": "0x40002000", "offset": 12, "msb": 31, "lsb": 0, "signed": true, "log_scale": 16},
        "alpha_d":  {"base": "0x40002000", "offset": 16, "msb": 31, "lsb": 0, "signed": true, "log_scale": 31},
        "gain":     {"base": "0x40002000", "offset": 20, "msb": 17, "lsb": 0, "signed": false, "log_scale": 9},
        "ireset":   {"base": "0x40002000", "offset": 24, "msb": 1,  "lsb": 1, "signed": false, "log_scale": 0},
        "reset":    {"base": "0x40002000", "offset": 24, "msb": 0,  "lsb": 0, "signed": false, "log_scale": 0}
    }
  }

  }
}

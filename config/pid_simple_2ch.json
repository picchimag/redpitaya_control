{
  "bitfile": "bitfiles/pid_simple_2ch.bit",
  "description": "Two PIDs each for each channel, each with its own params",
  "build_date": "2025-10-01",

  "modules": {

    "pid0": {
      "type": "pid_simple",
      "settings": {
        "LOG_DIV": 10,
        "LOG_A0": 16,
        "DATA_WIDTH": 32,
        "COEFF_WIDTH": 32,
        "GAIN_WIDTH": 18,
        "LOG_UNITY_GAIN": 9,
        "timebase_rp": 8e-9,
        "timebase_module": 8.192e-6
        },
      "registers": {
        "setpoint": {"base": "0x40000000", "offset": 0,  "msb": 31, "lsb": 0, "signed": true, "log_scale": 31},
        "Kp":       {"base": "0x40000000", "offset": 4,  "msb": 31, "lsb": 0, "signed": true, "log_scale": 16},
        "Ki":       {"base": "0x40000000", "offset": 8,  "msb": 31, "lsb": 0, "signed": true, "log_scale": 16},
        "Kd":       {"base": "0x40000000", "offset": 12, "msb": 31, "lsb": 0, "signed": true, "log_scale": 16},
        "alpha_d":  {"base": "0x40000000", "offset": 16, "msb": 31, "lsb": 0, "signed": true, "log_scale": 31},
        "gain":     {"base": "0x40000000", "offset": 20, "msb": 17, "lsb": 0, "signed": false, "log_scale": 9},
        "ireset":   {"base": "0x40000000", "offset": 24, "msb": 1,  "lsb": 1, "signed": false, "log_scale": 0},
        "reset":    {"base": "0x40000000", "offset": 24, "msb": 0,  "lsb": 0, "signed": false, "log_scale": 0}
      }
    },

    "pid1": {
      "type": "pid_simple",
      "settings": {
        "LOG_DIV": 10,
        "LOG_A0": 16,
        "DATA_WIDTH": 32,
        "COEFF_WIDTH": 32,
        "GAIN_WIDTH": 18,
        "LOG_UNITY_GAIN": 9,
        "timebase_rp": 8e-9,
        "timebase_module": 8.192e-6
        },
        "registers": {
        "setpoint": {"base": "0x40001000", "offset": 0,  "msb": 31, "lsb": 0, "signed": true, "log_scale": 31},
        "Kp":       {"base": "0x40001000", "offset": 4,  "msb": 31, "lsb": 0, "signed": true, "log_scale": 16},
        "Ki":       {"base": "0x40001000", "offset": 8,  "msb": 31, "lsb": 0, "signed": true, "log_scale": 16},
        "Kd":       {"base": "0x40001000", "offset": 12, "msb": 31, "lsb": 0, "signed": true, "log_scale": 16},
        "alpha_d":  {"base": "0x40001000", "offset": 16, "msb": 31, "lsb": 0, "signed": true, "log_scale": 31},
        "gain":     {"base": "0x40001000", "offset": 20, "msb": 17, "lsb": 0, "signed": false, "log_scale": 9},
        "ireset":   {"base": "0x40001000", "offset": 24, "msb": 1,  "lsb": 1, "signed": false, "log_scale": 0},
        "reset":    {"base": "0x40001000", "offset": 24, "msb": 0,  "lsb": 0, "signed": false, "log_scale": 0}
    }
  }

  }
}
